{"ts":"2026-06-03T05:07:42.319Z","author":"codex","op":"create","patch":[{"op":"add","path":"/metadata/id","value":"pm-github-o7jl"},{"op":"add","path":"/metadata/title","value":"Search provider maps remote matches to LOCAL items only"},{"op":"add","path":"/metadata/description","value":"pm runtime drops provider hits whose id is not a local document (normalizeExtensionProviderHits). So the github provider queries GitHub for the repo, then returns hits ONLY for issues that are already imported locally (matched by provenance tag). Semantics: 'find my imported items whose upstream issue matches this query'. Provider runs only in semantic/hybrid mode. Add 'search' to manifest only after verifying it activates + returns hits."},{"op":"add","path":"/metadata/type","value":"Decision"},{"op":"add","path":"/metadata/status","value":"open"},{"op":"add","path":"/metadata/priority","value":2},{"op":"add","path":"/metadata/tags","value":[]},{"op":"add","path":"/metadata/created_at","value":"2026-06-03T05:07:42.319Z"},{"op":"add","path":"/metadata/updated_at","value":"2026-06-03T05:07:42.319Z"},{"op":"add","path":"/metadata/author","value":"codex"},{"op":"add","path":"/metadata/parent","value":"pm-github-9dqy"}],"before_hash":"3cc22dff72be7b14824654a7a64ea62b04799939b2fee54c1b5f52ca60bf6df0","after_hash":"2c5992afb1c066e353cfed2c612038c941f5ee11725a4594b52ef282e72b9332","message":"decision"}
